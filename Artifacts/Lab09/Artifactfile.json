{
    "$schema": "https://raw.githubusercontent.com/Azure/azure-devtestlab/master/schemas/2016-11-28/dtlArtifacts.json",
    "title": "SQL Server Lab 09 (Web Download)",
    "description": "Downloads Lab 09 files from GitHub and prepares the SQL environment.",
    "publisher": "Thinh",
    "iconUri": "",
    "targetOsType": "Windows",
    "parameters": {
      "installType": {
        "type": "string",
        "displayName": "Installation Type",
        "description": "Select what to deploy to the VM",
        "allowedValues": ["Setup Only", "Solution Only", "Full Lab"],
        "defaultValue": "Full Lab"
      }
    },
    "tags": [
    "SQL Server",
    "SSMS 2022",
    "Lab"
     ],
    "runCommand": {
     "commandToExecute": "[concat('powershell.exe -ExecutionPolicy Unrestricted -File Setup-Lab09.ps1 -installType \"', parameters('installType'), '\"')]"
   }
  }
