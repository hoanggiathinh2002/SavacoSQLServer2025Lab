{
  "$schema": "https://raw.githubusercontent.com/Azure/azure-devtestlab/master/schemas/2016-11-28/dtlArtifacts.json",
  "title": "Install SQL Server 2025 Devtest Lab",
  "description": "Installs SQL Server silently using a configuration file. Idempotent and logs to C:\\Windows\\Temp\\dtl-artifact-logs.",
  "publisher": "Thinh",
  "iconUri": "https://raw.githubusercontent.com/yourrepo/icons/sql.png",
  "targetOsType": "Windows",
  "parameters": {
    "sqlInstallerUrl": {
      "type": "string",
      "displayName": "SQL Server Installer URL",
      "defaultValue": "https://go.microsoft.com/fwlink/?linkid=2342429&clcid=0x409&culture=en-us&country=us"
    },
    "sqlConfigUrl": {
      "type": "string",
      "displayName": "SQL Configuration File URL",
      "defaultValue": "https://storageaccount.blob.core.windows.net/installers/ConfigurationFile.ini"
    },
    "sqlEdition": {
      "type": "string",
      "displayName": "SQL Edition",
      "defaultValue": "Developer"
    },
    "rebootIfRequired": {
      "type": "string",
      "displayName": "Reboot If Required",
      "defaultValue": "true"
    }
  },
  "runCommand": {
  "commandToExecute": "powershell.exe -ExecutionPolicy Bypass -File install-sqlserver.ps1 -SqlInstallerUrl '[[parameters(\"sqlInstallerUrl\")]]' -SqlConfigUrl '[[parameters(\"sqlConfigUrl\")]]' -SqlEdition '[[parameters(\"sqlEdition\")]]' -RebootIfRequired '[[parameters(\"rebootIfRequired\")]]'"
  }
}
