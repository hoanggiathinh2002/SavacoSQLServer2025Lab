{
  "$schema": "https://raw.githubusercontent.com/Azure/azure-devtestlab/master/schemas/2016-11-28/dtlArtifacts.json",
  "title": "Microsoft SQL Server 2025 Developer Edition",
  "description": "Installs SQL Server 2025 Developer Edition using Chocolatey.",
  "publisher": "Savaco",
  "targetOsType": "Windows",
  "rebootBehavior": "never",
  "parameters": {
    "IsoPath": {
      "type": "string",
      "displayName": "ISO Path (optional)",
      "defaultValue": ""
    },
    "ProductKey": {
      "type": "string",
      "displayName": "Product Key (optional)",
      "defaultValue": ""
    },
    "IgnorePendingReboot": {
      "type": "bool",
      "displayName": "Ignore Pending Reboot",
      "defaultValue": false
    },
    "SqlSetupParameters": {
      "type": "string",
      "displayName": "Additional SQL Setup Parameters",
      "defaultValue": ""
    }
  },
  "runCommand": {
    "commandToExecute": "powershell.exe -ExecutionPolicy bypass -File ./install-sqlserver.ps1"
  }
}
