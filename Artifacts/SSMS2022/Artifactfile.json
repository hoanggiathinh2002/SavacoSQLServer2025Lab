{
  "$schema": "https://raw.githubusercontent.com/Azure/azure-devtestlab/master/schemas/2016-11-28/dtlArtifacts.json",
  "title": "Install SSMS 2022 Devtest Lab",
  "description": "Installs SSMS silently. Idempotent and logs to C:\\Windows\\Temp\\dtl-artifact-logs.",
  "publisher": "Thinh",
  "iconUri": "https://raw.githubusercontent.com/yourrepo/icons/sql.png",
  "targetOsType": "Windows",
  "parameters": {
    "ssmsInstallerUrl": {
      "type": "string",
      "displayName": "SSMS Installer URL",
      "defaultValue": "https://aka.ms/ssmsfullsetup"
    },
    "rebootIfRequired": {
      "type": "string",
      "displayName": "Reboot If Required",
      "defaultValue": "true"
    }
  },
  "runCommand": {
    "commandToExecute": "powershell -ExecutionPolicy Bypass -NoProfile -File install-ssms.ps1 -SsmsInstallerUrl \"{{ssmsInstallerUrl}}\""
  }
}
